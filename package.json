{
  "name": "devops-assignment",
  "version": "1.0.0",
  "description": "Node.js Express application with CI/CD pipeline",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev":   "nodemon app.js",
    "test":  "jest --coverage --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "express":     "^4.18.2",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "jest":      "^29.7.0",
    "nodemon":   "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageThreshold": {
      "global": {
        "branches":   70,
        "functions":  70,
        "lines":      70,
        "statements": 70
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
